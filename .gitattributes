# Normalize all text files to LF on commit
* text=auto eol=lf

# C# / .NET source files
*.cs        text eol=lf
*.csproj    text eol=lf
*.sln       text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.config    text eol=lf

# Web / config
*.json      text eol=lf
*.xml       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.ts        text eol=lf

# Docs / scripts
*.md        text eol=lf
*.txt       text eol=lf
*.sh        text eol=lf
*.ps1       text eol=lf
*.cmd       text eol=lf
*.bat       text eol=lf

# Binary files — no line ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.dll       binary
*.exe       binary
*.pdb       binary
